# ================================================================
#  CoreNova Bank – Environment Configuration Template
#  PDF Phase 6: Docker & Deployment
#
#  Usage:
#    cp .env.example .env
#    # then edit .env with real secrets (NEVER commit .env to git)
#
#  Used by: docker-compose.yml
#  Also mirrors keys in backend/src/main/resources/application.yml
# ================================================================

# ── PostgreSQL Database ─────────────────────────────────────────
DB_NAME=corenova_bank_db
DB_USERNAME=corenova_user
DB_PASSWORD=change_me_in_production
DB_PORT=5432

# ── Redis Cache ──────────────────────────────────────────────────
REDIS_PORT=6379

# ── JWT Authentication ───────────────────────────────────────────
# IMPORTANT: Generate a new random 256-bit+ secret for production.
# Example: openssl rand -base64 48
JWT_SECRET=CoreNovaBankSecretKey2025_ProductionKeyMustBeAtLeast256BitsLong!
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Application Ports ─────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── Spring Profile ─────────────────────────────────────────────────
# Options: dev | prod
# dev  → verbose console logs, hibernate SQL visible, ddl-auto=update
# prod → JSON file logging enabled, hibernate SQL suppressed
SPRING_PROFILE=prod

# ── Bank Identity (PDF §3 Architecture) ─────────────────────────────
BANK_NAME=CoreNova Bank
BANK_CODE=CNB
IFSC_PREFIX=CNB0
DEFAULT_BRANCH_CODE=MAIN001

# ── Transaction Limits (₹) ───────────────────────────────────────────
DEFAULT_DAILY_LIMIT=100000
UPI_PER_TXN_LIMIT=100000
RTGS_MINIMUM=200000
IMPS_LIMIT=500000

# ── pgAdmin (optional, dev profile only) ─────────────────────────────
PGADMIN_EMAIL=admin@corenova.bank
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
